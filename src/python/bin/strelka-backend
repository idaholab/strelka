#!/usr/bin/env python3
"""
strelka-backend

Command line utility for running Strelka backend server components.
"""
import argparse
from pathlib import Path

import strelka.config
import strelka.backend.redis
import strelka.plugins


def main():
    parser = argparse.ArgumentParser(
        prog="strelka-backend",
    )
    parser.add_argument(
        "-P", "--path",
        metavar="DIR",
        default=[],
        type=Path,
        action="append",
        help="additional location(s) to find plugins",
    )
    parser.add_argument(
        "-c",
        "--backend-cfg-path",
        type=Path,
        default=Path("/etc/strelka/backend.yaml"),
        help="path to backend configuration file",
    )
    args = parser.parse_args()

    config = strelka.config.BackendConfig(args.backend_cfg_path)
    config.configure_logging()
    strelka.plugins.register_plugin_paths(args.path)
    backend = strelka.backend.redis.RedisBackend(config)
    backend.work()


if __name__ == "__main__":
    main()
